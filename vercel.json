{
  "redirects": [
    {
      "source": "/project.html",
      "has": [{ "type": "query", "key": "id", "value": "tomexplore" }],
      "destination": "/projets/tomexplore.html",
      "permanent": true
    },
    {
      "source": "/project.html",
      "has": [{ "type": "query", "key": "id", "value": "tripenarvor" }],
      "destination": "/projets/tripenarvor.html",
      "permanent": true
    },
    {
      "source": "/project.html",
      "has": [{ "type": "query", "key": "id", "value": "deeppace" }],
      "destination": "/projets/deeppace.html",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
